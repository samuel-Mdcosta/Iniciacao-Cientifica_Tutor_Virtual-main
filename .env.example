# ==============================================================
# TUTOR VIRTUAL - INICIAÇÃO CIENTÍFICA
# Renomeie este arquivo para .env e preencha os valores abaixo
# ==============================================================

# ---------------------------
# Google Gemini API
# Obtenha em: https://aistudio.google.com/app/apikey
# ---------------------------
GEMINI_API_KEY=sua_chave_gemini_aqui

# ---------------------------
# Nomic AI (Embeddings)
# Obtenha em: https://atlas.nomic.ai/  →  Settings → API Keys
# ---------------------------
NOMIC_API_KEY=sua_chave_nomic_aqui

# ---------------------------
# MongoDB Atlas (Vector Store)
# Connection string no formato:
# mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# ---------------------------
MONGO_ADDRESS=mongodb+srv://usuario:senha@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=nome_do_banco
MONGO_COLLECTION=Chunk_Dinamic_NoOverlap
